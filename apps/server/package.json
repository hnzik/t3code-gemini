    "@google/gemini-cli-core": "^0.37.0",
    "@pierre/diffs": "^1.1.12",
    "effect": "catalog:",
    "node-pty": "^1.1.0",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@t3tools/contracts": "workspace:*",
    "@t3tools/shared": "workspace:*",
    "@t3tools/web": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.12.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
